# ============================================
# JARVIS — Environment Variables (API Keys)
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# === AI Providers ===
# At least ONE provider API key is required.
# Get keys from:
#   OpenAI:    https://platform.openai.com/api-keys
#   Anthropic: https://console.anthropic.com/
#   Google:    https://aistudio.google.com/app/apikey

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# === Voice ===
# Porcupine wake word (free access key from picovoice.ai)
# Sign up at: https://console.picovoice.ai/
PORCUPINE_ACCESS_KEY=

# === Default Provider Selection ===
# Which STT provider to use: openai, local (faster-whisper), deepgram
STT_PROVIDER=openai

# Which TTS provider to use: edge-tts (free), openai, elevenlabs
TTS_PROVIDER=edge-tts

# Which LLM provider to use: openai, anthropic, google, ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# === Local LLM (Ollama) ===
# OLLAMA_HOST=http://localhost:11434

# === Wake Word ===
WAKE_WORD=jarvis

# === Hardware ===
# Face display mode: terminal, pygame, hardware
FACE_MODE=terminal

# === Local LLM (LM Studio / Ollama) ===
# Your LM Studio API key (get from LM Studio > API Server tab)
LM_STUDIO_API_KEY=your_lm_studio_key_here

# === Vision ===
VISION_ENABLED=false
CAMERA_ID=0
